html
  head
    title= title
    meta(charset='utf-8')
    meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
    meta(name='description' content='cams staff database login page')
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous")
    link(rel="stylesheet", href="stylesheets/login.css")
  body
    .container
      h3.text-center.mt-5.text-white Cams Staff Database
      .row
        .col-sm-9.col-md-7.col-lg-5.mx-auto
          .card.card-signin.my-5
            .card-body
              h5.card-title.text-center Sign In
              form.form-signin
                .form-label-group
                  input#inputEmail.form-control(type='email' placeholder='Email address' required autofocus)
                  label(for='inputEmail') Email address
                .form-label-group
                  input#inputPassword.form-control(type='password' placeholder='Password' required)
                  label(for='inputPassword') Password
                button.btn.btn-lg.btn-primary.btn-block.text-uppercase(type='submit')
                  svg.bi.bi-arrow-right-circle-fill(xmlns='http://www.w3.org/2000/svg' width='20' height='20' fill='currentColor' viewBox='0 0 16 16')
                   path(d='M8 0a8 8 0 1 1 0 16A8 8 0 0 1 8 0M4.5 7.5a.5.5 0 0 0 0 1h5.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3a.5.5 0 0 0 0-.708l-3-3a.5.5 0 1 0-.708.708L10.293 7.5z')

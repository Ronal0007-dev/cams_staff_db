head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title= title
  link(rel='stylesheet' href='/stylesheets/datatables.css')
  link(rel='stylesheet' href='/stylesheets/datatables.min.css')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css' rel='stylesheet')
  link(href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/css/bootstrap.min.css")
  link(rel="stylesheet", href="/stylesheets/style.css")
  script(src='https://cdn.jsdelivr.net/npm/apexcharts')
#notification-container
.dashboard
  nav.sidebar
    .logo
      .logo-icon
        i.fas.fa-cube
      span CAMS STAFF DB
    ul.nav-links
      li(data-section='dashboard' data-content='dashboard-content' onclick="window.location.href='/'")
        i.fas.fa-home
        span Dashboard
        .nav-indicator
      //- li(data-section='analytics' data-content='analytics-content')
      //-   i.fas.fa-chart-line
      //-   span Analytics
      //-   .nav-indicator
      li.active(data-section='staff' data-content='staff-content' onclick="window.location.href='/staff'")
        i.fas.fa-users
        span Staff
        .nav-indicator
      li(data-section='department' data-content='department-content' onclick="window.location.href='/department'")
          i.fas.fa-cog
          span Department
          .nav-indicator
  main.main-content
    header
      .header-left
        .search-bar
          i.fas.fa-search
          input(type='text' placeholder='Search anything...')
      .header-right
        
        .profile
          .profile-trigger
            .profile-avatar
              span.avatar-text JD
            .profile-info
              span.profile-name John Doe
              span.profile-role Administrator
            i.fas.fa-chevron-down
          .profile-dropdown
            .dropdown-header
              .header-avatar
                span.avatar-text JD
              .header-info
                h4 John Doe
                span john.doe@example.com
            ul.dropdown-menu
              li.logout(href='/logout')
                i.fas.fa-sign-out-alt
                span Logout
    #dashboard-content.content-section.active
      .dashboard-grid
        .stats-container
          .stat-card.glow
            .stat-icon
              i.fas.fa-users
            .stat-details
              h3 Total Staff
              p.counter(data-target='15423') 0
              //span.trend.positive +12.5%
          .stat-card.glow
            .stat-icon
              i.fas.fa-book
            .stat-details
              h3 Teachers
              p.counter(data-target='84591') 0
              //span.trend.positive +8.2%
          .stat-card.glow
            .stat-icon
              i.fas.fa-cogs
            .stat-details
              h3 Non-Teaching Staff
              p.counter(data-target='24895') 0
              //span.trend.negative -2.4%
          .stat-card.glow
            .stat-icon
              i.fas.fa-id-badge
            .stat-details
              h3 Experties
              p.counter(data-target='1287') 0
              //span.trend.positive +5.7%
      button.btn.btn-primary(onclick="window.location.href='/staff/add'") Add New Staff
      block content 
  script(src="https://code.jquery.com/jquery-3.7.1.js")
  script(src='/javascripts/js/bootstrap.min.js')
  script(src="/javascripts/js/bootstrap.js") 
  script(src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.3.3/js/bootstrap.bundle.min.js")
  script(src="/javascripts/datatables.js")
  script(src="/javascripts/datatables.min.js")
  script(src="/javascripts/dashboard.js")
  script.
    $(document).ready(function() {
      $('#staff').DataTable();
    });
